#!/bin/bash -e

UDMI_ROOT=$(dirname "$0")/..
cd "$UDMI_ROOT"

IMAGE_NAME="udmi-agentic-exec"

# Verify docker
if ! command -v docker &> /dev/null; then
    echo "Error: docker command not found. Please install docker first." >&2
    exit 1
fi

if ! docker info &> /dev/null; then
    echo "Error: docker daemon is not running or not accessible." >&2
    exit 1
fi

# Always run docker build to pick up Dockerfile updates cleanly using caching
echo "Ensuring Docker image '$IMAGE_NAME' is up-to-date..."
docker build -t "$IMAGE_NAME" -f etc/Dockerfile.agentic_exec .

if [[ $# -eq 0 ]]; then
    echo "Usage: $0 <command> [arguments...]" >&2
    echo "Example: $0 bin/test_registrar" >&2
    exit 1
fi

# Pass-through relevant environment variables
ENV_ARGS=()
for var in TARGET_PROJECT UDMI_REGISTRY_SUFFIX UDMI_ALT_REGISTRY MATRIX_SHARD_COUNT MATRIX_SHARD_INDEX GITHUB_RUN_NUMBER; do
    if [[ -n "${!var:-}" ]]; then
        ENV_ARGS+=("-e" "$var=${!var}")
    fi
done

# Run the command inside the fully self-contained container with ZERO host mounts
echo "Executing command in isolated docker environment..."
docker run --rm -i \
    --name "udmi-agentic-$(date +%s)-$RANDOM" \
    -w "/root/udmi" \
    "${ENV_ARGS[@]}" \
    "$IMAGE_NAME" \
    bash -c "
        # 1. Start UDMIS (which automatically boots etcd and mosquitto if needed)
        echo 'Starting background services (mosquitto, etcd, UDMIS)...'
        bin/start_udmis
        
        # 2. Execute the user's command (supporting chained/compound commands)
        echo 'Executing command in container...'
        eval \"\$@\"
        exit \$?
    " -- "$@"
