FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Install dependencies matching GHA CI environment
RUN apt-get update && apt-get install -y \
    openjdk-21-jdk \
    python3 \
    python3-pip \
    python3-venv \
    python3-dev \
    moreutils \
    expect \
    mosquitto \
    mosquitto-clients \
    curl \
    jq \
    sudo \
    git \
    rsync \
    psmisc \
    procps \
    && rm -rf /var/lib/apt/lists/*

# Mock systemctl to always fail, forcing start_mosquitto to fall back to raw background process
RUN echo '#!/bin/sh\nexit 1' > /usr/bin/systemctl \
    && chmod +x /usr/bin/systemctl \
    && rm -f /bin/systemctl /sbin/systemctl /usr/sbin/systemctl 2>/dev/null || true

# Configure passwordless sudo
RUN echo "ALL ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Trust all directories in git (required for mounted and nested repos like site_model)
RUN git config --global --add safe.directory '*'

WORKDIR /root/udmi

# Copy files required for setup_base, clone_model, and requirements
COPY bin/setup_base bin/setup_base
COPY bin/which_venv_pip3 bin/which_venv_pip3
COPY etc/requirements.txt etc/requirements.txt
COPY etc/shell_common.sh etc/shell_common.sh
COPY bin/clone_model bin/clone_model
COPY bin/check_version bin/check_version
COPY udmis/bin/etcdctl udmis/bin/etcdctl

# Pre-download and extract etcd
RUN udmis/bin/etcdctl version

# Set up Python virtual environment in $HOME/venv (/root/venv) inside the image
RUN python3 -m venv /root/venv \
    && /root/venv/bin/pip install --upgrade pip \
    && /root/venv/bin/pip install -r etc/requirements.txt

# Clone the site model inside the image
RUN bin/clone_model

# Copy complete repository directories into the image to enable runtime compile isolation and zero host mounts
COPY bin/ bin/
COPY etc/ etc/
COPY schema/ schema/
COPY pubber/ pubber/
COPY sites/ sites/
COPY gencode/ gencode/
COPY common/ common/
COPY validator/ validator/
COPY udmis/ udmis/
COPY services/ services/

# Setup directories for Mosquitto with proper permissions
RUN mkdir -p /var/log/mosquitto /etc/mosquitto \
    && chown -R mosquitto:mosquitto /var/log/mosquitto /etc/mosquitto

# Pre-build certificates and Dynamic Security configurations for Mosquitto
RUN bin/setup_ca sites/udmi_site_model localhost \
    && mosquitto -c /etc/mosquitto/mosquitto.conf > /var/log/mosquitto/mosquitto.log 2>&1 & \
    MOSQ_PID=$! \
    && sleep 5 \
    && bin/start_mosquitto \
    && mosquitto_ctrl -h localhost -p 8883 -u scrumptious -P aardvark --cafile /etc/mosquitto/certs/ca.crt --cert /etc/mosquitto/certs/rsa_private.crt --key /etc/mosquitto/certs/rsa_private.pem dynsec createClient rocket -p monkey 2>/dev/null || true \
    && mosquitto_ctrl -h localhost -p 8883 -u scrumptious -P aardvark --cafile /etc/mosquitto/certs/ca.crt --cert /etc/mosquitto/certs/rsa_private.crt --key /etc/mosquitto/certs/rsa_private.pem dynsec addClientRole rocket service 2>/dev/null || true \
    && bin/mosquctl_site sites/udmi_site_model \
    && kill $MOSQ_PID
